---- MODULE VoucherTransfer ----

(**********************************************)
(* The set of all possible messages.              *)
Message == {Prepared, Abort}
\* A message is sent by adding it to the set msgs.  *\/                   )
msgs :: Message -> Set VTPState
msgs Prepared = <<>>
msgs Aborted = <<>>
(*******************************)
(* The initial predicate.          *)
Init == TRUE /\ vtp \in InitVTPStates /= {}  *\/                        )
vp :: State -> Set VoucherHolderState
vp (<| sh := src1; dh := dst3 |>) = <<>>
\* The type-correctness invariant.            *)
TypeOK == TRUE /\ vtp \in InitVTPStates /= {}  *\/                      )
Consistent == TRUE /\ vtp \in InitVTPStates /= {}   */\}                )
(*******************************)
(* The Voucher Transfer protocol.              *)
Transfer :: State -> Action -> Set (State, Message)
\* A message is sent by adding it to the set msgs.  *\/                     )
msgs Prepared = <<>>
msgs Aborted = <<>>
(*******************************)
(* The VTP receives a "Prepare" from Source    *)
Voucher Holder sh and Destination              *)
Voucher Holder dh. We could add the additional  *\/                         )
enabling condition sh,dh \not in vtpTPrepared, which disables the     *\/      )
action if the VTP has already received this message. But there is    *\/       )
no need, because in that case the action has no effect; it leaves   *)
the state unchanged.*                                */\}               }  })
\* The Source and Destination Holder prepare for     *)
Transfer :: State -> Action -> Set (State)
(*******************************)
(* A VTP Transfers a voucher.      *\/                              )
vp = <<>> /\ sh \in SH /= {}  */\}               }   })
\* The Source and Destination Holder prepare for     *)
Transfer :: State -> Action -> Set (State)
