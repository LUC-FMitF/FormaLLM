---- MODULE ClientCentric ----- -----------------------------------------------------
EXTENDS FiniteSets, Naturals, Sequences; -- import sets and sequences from TLA+ standard library.
---------------------------------------- EXTENDED FROM FINITESETS/NATURALS/SEQUENCES MODULE ---
-- Define constants for Read Committed isolation level: 1 (highest), Strict Serializability, etc...
CONSTANTS ISOLATION_LEVEL = 2; -- For example purposes we set this to a constant. You might want it dynamic based on your application or system you're modelling.

-- Define types and constants shared by the whole module: TimeStamp, Operation etc...
TYPE State = [k \in Keys |-> Values] -- A state is a map from keys to values (a database).
   CONSTANTS InitValue;                ---- Initial value for all states. Can be defined as bottom (_|_) or any valid initial condition based on your application/system modeled by TLA+ code generator. ----------
TYPE Operation = [op: {"Read", "Write"}, key : Keys, val?: Values] -- An operation is a read (or write) of a value for some Key in the database state. It can be partial if it's just reading from/writing to this particular key-value pair and not all values present across keys or states
TYPE Transaction = [ops: Seq(Operation), start, commit : TimeStamp] -- A transaction is an ordered sequence of operations with a timestamp at the beginning (start) & end (commit). It's represented as pairs in TLA+. ---------------------------------------------- EXTENDED FROM SEQUENCES MODULE
TYPE ExecutionElem = [parentState: State, txn : Transaction , resultState: State] -- An execution is a sequence of transactions with their corresponding parent state and the resulting states after applying all operations in that transaction to some initial (or previous) system/state. ------------------------------------------------ EXTENDED FROM ClientCentricIsolation
OPERATIONS Reads = \x, y : x[y]\_ -- Helper operation for reading from a key-value pair state [key: value] where `Read(State1, KeyName)[ValueOfKeyInThatState];` returns the Value of that particular State. ---------------------------------------------- EXTENDED FROM FiniteSets
OPERATIONS Writes = \x, y : x[y]\_ -- Helper operation for writing to a key-value pair state [key: value] where `Write(InitialConditionOfSystemState1,"KeyName",ValueToBeWritten)[NewConditionsAfterWriting];` returns the New State after write. ---------------------------------------------- EXTENDED FROM FiniteSets
OPERATION ReadStates = \s, t : {x: y\in s |-> (Read(y)(t))} -- The read states operation gives us a subset of States that can be accessed by transaction `Transaction1` from state `State0 -T-->` State. ---------------------------------------------- EXTENDED FROM FiniteSets
OPERATION CT_SER = \transaction, execution : TransactionInExecution(execution) && SerializableByCommitTime[transaction] -- Checks if a given commit time (time of transaction's end in oracle clock/wall-clock ) satisfies serializability. ---------------------------------------------- EXTENDED FROM ClientCentricIsolation
OPERATION CT_SS = \state, txn : state -*--> TxToState(txns)[TxInOrderedSet] -- Checks if a given transaction in ordered set of transactions can be applied to the parent (previous) system/state. ---------------------------------------------- EXTENDED FROM FiniteSets
OPERATION CT_RC = \transaction, state : NoConflict[StateToTransactions(transactions)[txn]] -- Checks if a given transaction does not conflict with previous transactions in its read states by checking for key value changes between two consecutive system/states. ---------------------------------------------- EXTENDED FROM FiniteSets
OPERATION CT_RU = \transaction, state : [op: Operation |-> (Read(state)(Op[key]) == Op[val] iff op in transaction)] -- Checks for read uncommitted isolation level where a reader can see the value of data that has not yet been committed. ---------------------------------------------- EXTENDED FROM FiniteSets
OPERATION CheckTypes = \txn : ((\A x: X_in(Operations[Tx]) /\ ReadStates => Transaction) && (\E y:(Yields in Operations)/CheckType)) -- Checks for valid operations and if they are of correct type. ---------------------------------------------- EXTENDED FROM FiniteSets
OPERATION PrintState = \state : [Keys: Values |-> (Print(Key, Value)] - prints each key with its corresponding value in the state/database. ------ TLA+ builtin operation to print a database's keys and values ------------------------------------------------ EXTENDED FROM FiniteSets
OPERATION SerializabilityDebug = \initialState: State , transactions : Seq(Transaction) == -- Checks for serializable execution by checking if any of the executions satisfy CT_SER. If not, prints all such non-serialized ones. ------------------------------------------------ EXTENDED FROM ClientCentricIsolation
-- Define functions/operations that generate permutation sets and checks: GeneratePermutations , PermuteTransactions etc... ------------------------------------------------------------------------------------------- FUNCTIONS DEFINITION END HERE (But operations are defined in the beginning)------------------------------------------------------------------------- OPERATION CALLING SEQUENCE STARTS FROM THIS POINT
BEGIN -- BEGIN OF COMPUTED GROUPS/OPERATOR OVERRIDES --------------------------------- EXTENDS Sequences & ClientCentricIsolation MODULE.
