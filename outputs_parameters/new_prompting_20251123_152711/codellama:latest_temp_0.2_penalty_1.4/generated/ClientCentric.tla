---- MODULE ClientCentric ----
------------------------------ CLIENT-CENTRIC ISOLATION --------------------
(* TODO: Add support for other isolations levels, such as snapshot and read committed *)
******************************* DEFINITIONS ****************************)
CONSTANT Keys == {0 .. 1} (* The set of keys in the system. *)
TYPE Value = Int \* A value can be any integer between -2^31-1 to +2^31-1, inclusive.*)
\* An initial state is a mapping from each key k in Keys to its corresponding inital value InitValue*)
CONSTANT InitialState == [k |-> 0] \* The set of keys and their respective values. *)
TYPE TimeStamp = Int (* A timestamp can be any integer between -2^31-1 to +2^31-1, inclusive.*)
\** An execution is a sequence of operations (reads or writes).*)
CONSTANT Execution == [ops: Seq(Operation), start: TimeStamp] \* The set of all possible permutations. *)
TYPE Operation = Read | Write (* A read operation reads the value associated with some key, while write updates that same key to a new value.*)
\** An execution element is an individual transaction in our system*)
CONSTANT ExecutionElem == [parentState: State, transaction: Transaction] \* The parent state of each transaction. *)
TYPE TimeStamp = Int (* A timestamp can be any integer between -2^31-1 to +2^31-1, inclusive.*)
\** An execution is a sequence of operations (reads or writes).*)
CONSTANT Execution == [ops: Seq(Operation), start: TimeStamp] \* The set of all possible permutations. *)
