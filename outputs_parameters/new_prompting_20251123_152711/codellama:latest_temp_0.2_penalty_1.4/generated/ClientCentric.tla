CONSTANT ExecutionElem == [parentState: State, transaction: Transaction] \* The parent state of each transaction. *)
TYPE TimeStamp = Int (* A timestamp can be any integer between -2^31-1 to +2^31-1, inclusive.*)
\** An execution is a sequence of operations (reads or writes).*)
CONSTANT Execution == [ops: Seq(Operation), start: TimeStamp] \* The set of all possible permutations. *)
