---- MODULE MCDieHarder ----

(**************************************************************************)
(* The following definitions duplicate the original Die Hard problem.  *)
(**************************************************************************)

CONSTANTS Goal     \* The goal value for which we are searching.      *)
    =  4            (* This is a constant that will be used in       *)
                    (* Spec and Invariants to specify the problem's  *)
                    (* constraints on the values of Jug, Capacity,  *)
                    (* and Goal.                                     *)
CONSTANTS Jug      \* The number of jars that can be used in a       *)
                    * single move (a constant).                       
           <- MCJug  
          Capacity \* A function giving the capacity for each jar,  *)
                    * given its value. This is also a constant     *)
                    (* whose domain will need to be specified in   *)
                    (* TLC's configuration file (see below).        *)
           <- MCCapacity
--------------------------- SPECIFICATION Spec ---------------------------
Init == \* The initial predicate.  It is true if the current state     *)
       * satisfies all of the problem constraints, and it will be      *)
       * used in TLC's search to determine whether a solution exists   *)
        /\ Goal = Capacity[Jug]                                (* This formula expresses that the goal value is equal to the capacity for the current number of jars.  It must hold true at all times during the execution, which means it will be used in TLC's search as a constraint on the values of Jug and Goal. *)
        /\ \A i \in DOMAIN Capacity :                           (* This formula expresses that for each value "i" appearing in the domain (keys) of the function Capacity, we must have: 1/ The current number of jars is less than or equal to this capacity; and 2/) For all values "jug" such that i <= jug < i + Jug, the goal value will be greater than or equal to the sum of these capacities. *)
            Goal >= Capacity[i] /\ \A jug | (i <= jug < i + Jug) : (* This formula expresses that for each "jug" such that the current number of jars is less than or equal to this value and greater than or equal to its previous value plus 1, we must have: *)
                Goal >= Sum {cap | (i <= jug < i + Jug) /\                            (* This formula expresses that for each "jug" such that the current number of jars is less than or equal to this value and greater than or equal to its previous value plus 1, we must have: *)
                    cap \in DOMAIN Capacity :                           (* This formula expresses that for all values in the domain (keys) of the function Capacity, we will need to specify a value. *)
