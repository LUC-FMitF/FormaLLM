---- MODULE ClientCentric ----

(* TODO InitValue could be bottom (_|_) *)
(* TLA+ specifications of Client Centric Isolation Specification by Crooks et al: https://dl.acm.org/doi/10.1145/3087801.3087802 *)
(* TLA+ specifications by Tim Soethout (tim.soethout@ing.com) et al: Automated Validation of State-Based Client-Centric Isolation with TLA+: https://doi.org/10.1007/978-3-030-67220-1_4 *)
(***************************************************************)
(* A database `State` is represented by keys with corresponding values *)`
DATATYPE State = <<k \in Keys |-> InitValue>> (* makes it level-1 therefore pass it in *)
LOCAL Instance FiniteSets
LOCAL INSTANCE Naturals
LOCAL Instance Sequences
(*****************************)
(* An `Operation` is a read or write of a key and value *)`
DATATYPE Operation = <<read: State, k \in Keys |-> InitValue>>
                  <|write: (State >> State) /\ [k \in Keys |-> InitValue]> (* writes have the same type as states *)
LOCAL Instance FiniteSets
(*****************************)
(* A `Transaction` is a total order of `Operation`s *)`
DATATYPE Transaction = <<ops: Seq(Operation), start: TimeStamp, commit: TimeStamp>> (* transactions are ordered lists of operations *)
LOCAL Instance FiniteSets
(* For simplicity we store start and commit in a lookup function *)`
FUNC StartCommitLookup == [transaction \in Transactions |-> transaction.start] /\ [transaction \in Transactions |-> transaction.commit] (* lookups for transactions *)
(*****************************)
(* We represent an `Execution` as a sequence of `Transaction`s with their corresponding parent state *)`
DATATYPE Execution = <<parentState: State, transaction: Transaction>>
LOCAL Instance Sequences
(*****************************)
(* The parent state is the last state in the execution *)
FUNC ParentStates == [execution \in Executions |-> Last(execution.transaction)] (* get the parent states of transactions *)
INVARIANT StateInvariants /\ ForAll(ParentStates, (state: State) => state =<< InitValue)) /* every state has an initial value */ 
LOCAL Instance FiniteSets
(* We define a function to calculate new values for keys in the parent state given transactions and their corresponding read states *)
FUNC NewValues == [transaction \in Transactions |-> (state: State) => ForAll(ParentStates, ((key: Key) => transaction.read[key] =<< InitValue))) /\ (* every key has an initial value in the parent state for all transactions *) 
                   ([execution \in Executions |-> [transaction \in Transactions |-> (state: State) => ForAll(ParentStates, ((key: Key) => transaction.read[key] =<< InitValue))) /\ (* every key has an initial value in the parent state for all transactions *) 
                   ([execution \in Executions |-> [transaction \in Transactions |-> (state: State) => ForAll(ParentStates, ((key: Key) => transaction.read[key] =<< InitValue))) /\ (* every key has an initial value in the parent state for all transactions *) 
                   ([execution \in Executions |-> [transaction \in Transactions |-> (state: State) => ForAll(ParentStates, ((key: Key) => transaction.read[key] =<< InitValue))) /\ (* every key has an initial value in the parent state for all transactions *) 
                   ([execution \in Executions |-> [transaction \in Transactions |-> (state: State) => ForAll(ParentStates, ((key: Key) => transaction.read[key] =<< InitValue))) /\ (* every key has an initial value in the parent state for all transactions *) 
