---- MODULE ClientCentric -------------------------------------------------------
EXTENDS FiniteLinearOrders, NaturalsLibrary(Nat), SequenceOperations; (* import necessary modules *)  
-----------------------------------------------------------------------------------    CONSTANTS     ------------------------------------------------------------------------       INITIAL_STATE == [k \in Keys |-> InitValue] * makes it level 1 therefore pass in      EXECUTION := <<>> ;(* empty execution sequence to accumulate ExecutionElems*)         CTI(transaction,execution) ==  (* check if specific transaction is valid under given state *)        [parentState: State , resultant_state = NextStates[Parents.NextOpSequence], parentTransaction] ==       ([(kv \in Parent : k -> v)] ++ TransactionOperationsIncludingReadOnly(transaction)) /\ (* check if transaction can be applied on previous state *)         CTI'(transactions,execution) ==  EXISTS t:[t' ∈ transactions |-> ~CT_SERIALIZABLE[Parents.NextOpSequence]] ;(* checks for serializability of a set of operations in given execution*)       NextStates == [kv \in State : k -> Value] /\ (* calculator to get next state *)        CTI''(transaction,execution) ==  ([(resultant_state = Parents.NextOpSequence)]/\ ((~CTIS[ParentState](transactions)) => True ));(* checks for isolation level of a transaction in given execution*)       IsolationLevel == EXISTS t:[t' ∈ transactions |-> CTI''(transaction,execution)]; (* Definition to check if set T satisfies an isolated *)  
-----------------------------------------------------------------------------------    FUNCTIONS     ------------------------------------------------------------------------      OperationsIncludingReadOnly ==  [operation: Operation] /\ (((k ->  Value)) = operation));(* helper function that includes read operations*)       NextStates == EXISTS state:[s' ∈ State |-> CTI(transaction,execution)]; (* calculator to get next states *)      TransactionOperationsIncludingReadOnly ==  [operation: Operation] /\ (((k ->  Value)) = operation));(* helper function that includes read and write operations*)       ParentState == EXISTS execution:[e ∈ Execution |-> CTI(transaction,execution)]; (* calculator to get parent state *)      ReadStatesForEmptyTransaction ==  [state: State] /\ ((k ->  Value)) = InitValue);(* helper function that includes all previous states*)       IsSerializable == EXISTS execution:[e ∈ Execution |-> CTI'(transactions,execution)]; (* checks if a set of transactions T satisfies an isolation level *)        SerializabilityDebug ==  (~Isolate(transaction)) => PrintT[<<"Execution not serialized:", transaction>>]);(* helper function to print non-serializable executions*)       IsolationLevel == EXISTS t:[t' ∈ Transactions | -> CTI'''(transaction,execution)]; (* Definition for checking isolation level of a set *)  
-----------------------------------------------------------------------------------    SPECIFICATION ------------------------------------------------------------------------      Spec ==  /\ InitValue \in Values                      /\ PrintT(State);(* check types in derived specification*)        EXECUTION' == [e ∈ Execution | -> (CTI'''(transaction,execution) => e)] ; (* store execution *)       Isolate_Levels = {Isolation : Level & InitValue \in Values};
-----------------------------------------------------------------------------------    INVARIANTS     ------------------------------------------------------------------------      Inv ==  EXECUTION' /\ [e ∈ Execution | -> CTI'''(transaction,execution)]; (* invariants for execution *)  =============================================================================================== END MODULE ======================================================================================================  ----- TLC Configuration:
CONSTANTS InitValue  = _|_ (bottom), Keys = 0..(n –1);; SPECIFICATION Spec ; INVARIANTS Inv.     ===> End of file <===   This is a basic representation, you might need to add more details based on your exact requirements and the actual implementation in TLA+ language as per Crooks et al's Client Centric Isolation specification mentioned above
====