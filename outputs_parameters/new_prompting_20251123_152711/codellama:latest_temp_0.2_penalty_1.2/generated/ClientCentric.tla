---- MODULE ClientCentric ----

(* TODO InitValue could be bottom (_|_) *)

CONSTANT Keys = {0, 1, ...} (* set of all possible keys in the system *)
CONSTANT Values = {a, b, c, d, e} (* set of all possible values for each key *)
CONSTANT InitValue == a (* initial value for each key *)

(* A database `State` is represented by keys with corresponding values *)
DATATYPE State = <<k \in Keys |-> v: Values>>

(* An `Operation` is a read or write of a key and value *)
DATATYPE Operation = Read(key: Keys) | Write(key: Keys, value: Values)

(* A `Transaction` is a total order of `Operation`s *)
DATATYPE Transaction = <<ops: Seq(Operation), start: TimeStamp>>

(* For simplicity we store start and commit in a lookup function *)
FUNCTION CommitTime(transaction: Transaction): TimeStamp
  RETURNS (commit: TimeStamp)
  ASSUMES transaction != <<>> (* empty transactions are not allowed *)
  WITH transaction.start + LENGTH(transaction.ops) AS commit

(* An execution e for a set of transactions T is defined by the pair (Se,−−t \in T−→), where Se is the set of states generated by applying, starting from the system’s initial state, a permutation of all the transactions in T . *)
DATATYPE Execution = <<parentState: State, transaction: Transaction>>

(* We represent an `Execution` as a sequence of `Transaction`s with their corresponding parent state. Note: This execution does therefore not contain the "final state" of the execution, since it is not a parent state of a transaction. *)
DATATYPE ExecutionElem = <<parentState: State, transaction: Transaction>>

(* A state `s` is complete for `T` in `e` if every operation in `T` can read from `s`. We use this to ensure that the execution satisfies the isolation level. *)
FUNCTION IsComplete(executionElem: ExecutionElem, transactions: Seq(Transaction)): BOOLEAN
  RETURNS (complete: BOOLEAN)
  ASSUMES executionElem != <<>> (* empty transaction is not allowed *)
  WITH LENGTH(transactions) = 0 AS complete
    [] LENGTH(transactions) > 0 AND NOT EXISTS t \in transactions : NOT IsReadable(executionElem.parentState, t) AS complete
      TRUE
      FALSE

(* readStatesForEmptyTransaction contains all previous states, to ensure that empty txns do not incorrectly invalidate the checked isolation level *)
CONSTANT ReadStates = <<>> (* set of all possible read states for an operation in a transaction *)

(* The write set of T comprises the keys that T updates: WT = {k|w(k, v) ∈ ΣT }. For simplicity of exposition, we assume that a transaction only writes a key once. *)
FUNCTION WriteSet(transaction: Transaction): Set(Keys)
  RETURNS (writeSet: Set(Keys))
  WITH {key \in Keys |-> value} : NOT EXISTS op \in transaction.ops : NOT IsWriteOp(op) AS writeSet
    [] LENGTH(transaction.ops) > 0 AND NOT EXISTS t \in transactions : NOT IsReadable(executionElem.parentState, t) AS complete
      TRUE
      FALSE

(* Denoting the set of keys in which s and s′ differ as ∆(s, s′), we express this as NO-CONF_T (s) ≡ ∆(s, sp) ∩ WT = ∅ *)
FUNCTION NoConflict(state: State, transaction: Transaction): BOOLEAN
  RETURNS (noConflict: BOOLEAN)
  WITH NOT EXISTS key \in Keys : NOT IsReadable(state, transaction) AS noConflict
    TRUE
    FALSE

(* Given a set of transactions T and their read states, a storagesystem satisfies an isolation level I iff ∃e:∀t ∈ T :CTI(t,e). *)
FUNCTION SatisfiesIsolationLevel(transactions: Seq(Transaction), commitTest: Transaction -> BOOLEAN): BOOLEAN
  RETURNS (satisfiesIsolationLevel: BOOLEAN)
  WITH LENGTH(transactions) = 0 AS satisfiesIsolationLevel
    [] EXISTS t \in transactions : NOT IsReadable(executionElem.parentState, t) AS complete
      TRUE
      FALSE

(* Definition 5 Given a set of transactions T and their read states, a storagesystem satisfies an isolation level I iff ∃e:∀t ∈ T :CTI(t,e). *)
FUNCTION CheckTransactionSatisfiesCommitTest(transaction: Transaction, commitTest: Transaction -> BOOLEAN): BOOLEAN
  RETURNS (satisfiesCommitTest: BOOLEAN)
  WITH NOT EXISTS t \in transactions : NOT IsReadable(executionElem.parentState, t) AS complete
    TRUE
    FALSE

(* Definition 5 Given a set of transactions T and their read states, a storagesystem satisfies an isolation level I iff ∃e:∀t ∈ T :CTI(t,e). *)
FUNCTION CheckExecutionSatisfiesCommitTest(executionElem: ExecutionElem, commitTest: Transaction -> BOOLEAN): BOOLEAN
  RETURNS (satisfiesCommitTest: BOOLEAN)
  WITH NOT EXISTS t \in transactions : NOT IsReadable(executionElem.parentState, t) AS complete
    TRUE
    FALSE

(* Helper: checks if specific execution satisfies given commit test *)
FUNCTION CheckExecutionSatisfiesIsolationLevel(executionElem: ExecutionElem, isolationLevel: Transaction -> BOOLEAN): BOOLEAN
  RETURNS (satisfiesCommitTest: BOOLEAN)
  WITH NOT EXISTS t \in transactions : NOT IsReadable(executionElem.parentState, t) AS complete
    TRUE
    FALSE

(* Helper: checks if specific execution satisfies given commit test *)
FUNCTION CheckTransactionSatisfiesIsolationLevel(transaction: Transaction, isolationLevel: Transaction -> BOOLEAN): BOOLEAN
  RETURNS (satisfiesCommitTest: BOOLEAN)
  WITH NOT EXISTS t \in transactions : NOT IsReadable(executionElem.parentState, t) AS complete
    TRUE
    FALSE

(* Helper: checks if specific execution satisfies given commit test *)
FUNCTION CheckIsolationLevelSatisfiesCommitTest(isolationLevel: Transaction -> BOOLEAN, transaction: Transaction): BOOLEAN
  RETURNS (satisfiesCommitTest: BOOLEAN)
  WITH NOT EXISTS t \in transactions : NOT IsReadable(executionElem.parentState, t) AS complete
    TRUE
    FALSE

