---- MODULE Hanoi ----

(*****************************************************************************)
(* Defines a behavior for the Tower of Hanoi puzzle.                      *)
(*****************************************************************************)
CONSTANTS   D, N           \* The number of disks and towers in the system.  * )
VARIABLES bigTower, smallTower    \* A tower is represented by a natural     * )
                                number between (0,2^D].                      *)
INVARIANTS NotSolved           \* The puzzle has not been solved yet.       * )
------------------------------ INITIAL PREDICATE ----------------------------  )
Init == /\ D > N              \* All disks are on the first tower (big).     * )
      /\\ DOMAIN bigTower = {0..(2^D-1)}                                    *)
        AND ALL x: smallTower |-> y : bigTower [x] == 0                *)   \* All disks are on the first tower (big).     * )
      /\\ DOMAIN smallTower = {0..(2^D-1)}                               *)
       /\ NotSolved             \* The puzzle has not been solved yet.    *)
------------------------------ NEXT PREDICATE ----------------------------  )
Next == MoveBigToSmall     \* A disk can be moved from the big   * )
      /\\ DOMAIN smallTower = {0..(2^D-1)}                       *)
        AND ALL x: bigTower |-> y : smallTower [x] != 0         *)    tower to a smaller one.     * )
MoveBigToSmall == /\ D > N   \* The disk can be moved from the      * )
              /\\ DOMAIN bigTower = {0..(2^D-1)}                       *)
                AND ALL x: smallTower |-> y : bigTower [x] != 0     *)    tower to a smaller one.     * )
               /\ NotSolved             \* The puzzle has not been   * )
              /\\ DOMAIN smallTower = {0..(2^D-1)}                       *)
                AND ALL x: bigTower |-> y : smallTower [x] != 0     *)    solved yet.               *)
MoveSmallToBig == /\ D > N   \* The disk can be moved from the      * )
              /\\ DOMAIN bigTower = {0..(2^D-1)}                       *)
                AND ALL x: smallTower |-> y : bigTower [x] != 0     *)    tower to a smaller one.     * )
               /\ NotSolved             \* The puzzle has not been   * )
              /\\ DOMAIN smallTower = {0..(2^D-1)}                       *)
                AND ALL x: bigTower |-> y : smallTower [x] != 0     *)    solved yet.               *)
