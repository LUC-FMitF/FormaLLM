---- MODULE TwoPhase ----
\* =============================================================================
\* Two-phase handshake
\* =============================================================================

\* =============================================================================
\* Model
\* =============================================================================
MODULE TwoPhaseHandshake
  EXTENDS Alternate
  CONSTANTS RM = {r1, r2, r3}
  VARIABLES p, c
  INVARIANT TPTypeOK
  SPECIFICATION TPSpec

\* =============================================================================
\* Operators
\* =============================================================================

\* =============================================================================
\* Specification
\* =============================================================================
TPSpec ==
  [] (A_0 = p ∧ A_1 = c)
  U [](A_0 = c ∧ A_1 = p)

\* =============================================================================
\* Invariant
\* =============================================================================
TPTypeOK ==
  [] (p = c)

\* =============================================================================
\* TLC Configuration
\* =============================================================================
TLC_CONFIG ==
  CONSTANT RM = {r1, r2, r3}
  INVARIANT TPTypeOK
  SPECIFICATION TPSpec

\* =============================================================================
\* Proofs
\* =============================================================================
PROOF OF TPTypeOK ==
  [] (A_0 = p ∧ A_1 = c)
  U [](A_0 = c ∧ A_1 = p)

\* =============================================================================
\* Import Operators
\* =============================================================================
FOR EACH D IN ALTERNATE
  DEFINE A!!D ==
    []((vBar = p) => A_0 = p /\ (vBar = c) => A_1 = c)
    UNION
    []((vBar = c) => A_0 = c /\ (vBar = p) => A_1 = p)
    UNION
    ALTERNATE(D)
====