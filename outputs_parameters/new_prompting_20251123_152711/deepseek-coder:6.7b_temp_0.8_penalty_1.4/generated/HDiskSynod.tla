---- MODULE HDiskSynod -----

(***************************************************************************************)
(* Modification History                                                                 *)
(* Last modified Sat Jan 26 15:52:41 CET 2019 by tthai                                    *)
(* Created       Sun Jan 27 13:28:30 GMT+05 2019 by TLA Plus User                       *)
(***************************************************************************************)
CONSTANTS NotAnInput,      (* Represents no input or any unrecognized command.           *)  
          InputTransferred(* Indicates a deposit/withdrawal is made into the account       .  *)            	    		        			   	   									                      							                     						       								                    	                        
VARIABLES bk                (* Represents one bank, consisting of an input and balance.   * )     	 	       	     	          
          bal(bk) = 0 ,            inp (bk),                 out      		                  *)   	   									                                                   			 						    								        							       
INVARIANTS Inv_Balance == (\* The invariants for the bank account.                        * )     	 	       	     	          
          bk /\bal = SUM {x : x \in inp} - out,                  (* balance should be equal to total input minus outputs *)      		                				                                             			 						    								        							       	   					  
(* The bank account is empty initially.                                                * )     	                       	     	 	       	          
Init == bk /\ bal = 0 \/ inp = {} \/ out={}                                   (* Assume that the input and output are initialized to zero at start *)         		                				                                             			 						    								        							       	   					  
(* There is no unrecognized command or deposits into an empty bank account.           * )     	 	            	     	              bk /\ (bal = 0 ==> inp = NotAnInput)    (* This condition ensures that if the balance becomes zero, it means there are no more inputs and hence all outputs have been read *) 			
TransSpec_Outcome==    ~(bk/\ bal=o \/ out > 0),                    (*( The output should not be greater than total input or else unrecognized command is made )*))         		                				                                             			 						       								        							  	   					      	                    	 
(* A deposit into the account will add a positive value to balance.                      * *)     	       	     	           bk /\ x > 0 ==> (inp = InputTransferred, bal'=bal+x)     (* When an input of any amount is made in to bank then it increases the current balance by that much*) 			
DepositSpec==      ~(bk/\ ~((out = 1 /\ x > 0 ==> (inp = InputTransferred, bal'=bal+x))), (* The deposit operation should not be performed if no more outputs are there or the amount to transfer is negative *) 			
(* A withdrawal from an account will subtract a positive value balance.                  * )     	 	       	     	           bk /\ x > 0 ==> (out' = out + 1, bal'-=x)     (* When any output of same amount as input in to bank then it decreases the current balance by that much *)
WithdrawalSpec==  ~(bk/\ ~((inp = 2 	/\,bal-y>=o,\ b k ,\ y > 0 ==> (out = OutputTransferred, bal'-=x))), (* The withdraw operation should not be performed if there are no more inputs or the balance is going negative *)  
Next==    \E x : Naturals [(inp' =  InputTransferred,\ bk',\  y:Natural /\, (y > 0 ==> bal+=x))]/(out'/ = out + 1)     (* Specifies how to transition between states of the bank account, i.e., deposit operation *)
       \E x : Naturals [(inp' =  NotAnInput,\ bk',\  y:Natural /\, (y > 0 ==> bal-=x))]/(out'/ = out + 1)         (* Specifies how to transition between states of the bank account, i.e., withdrawal operation *)
Spec== Init/\ []Next \/ TransOutcome,\ DepositSpec and WithdrawalSpec 		               	(* It specifies that we start from an initial state (Init), followed by a next-state relation; additionally two other specifications are added which ensure the correctness of bank operations.*)     	 	       	     
===========================================================================================
====(*********************************************** TLC Configuration *******************************************************************)
CONSTANTS  InitDelay = 1,    (* delay to initialize all variables *)  	(* The initial model setup is delayed by one step for initialization and execution begins at the next state.*)    		        			       	   									                    						      							     	 	     	       								         		          
            NextDelay =0 ,   (**/delay between successive states * )  (* Transition to another state immediately after a successor relation is defined *)   	            		                				                                         			             		                                    	 	     	        
InvMode= "LTL",               (* Specifies the invariant checking mode as LTL - Linear Spatial Temporal Logic, which uses temporal operators like [ ] and /\ for specifying invariants.*)     							          						   	   					    				               			  		 	 	     	      
Property = "[<>](bk)<=>(bal=0)",(* The property to check in the model *) (* It checks if at any point of time, a bank is empty or not ie., its balance should be zero*)                  							          						   	   					    				               			  		 	 	     	      
===========================================================================================