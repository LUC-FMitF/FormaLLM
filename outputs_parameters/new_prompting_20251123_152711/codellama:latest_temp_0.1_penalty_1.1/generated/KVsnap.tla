---- MODULE KVsnap ----

(**********************************************)
(* A simple key-value store exhibiting snapshot isolation. If two       *)
(* concurrent transactions write to the same key, the one merging later*)
(* will be rejected. If they write different keys both will succeed. For  *)
(* a more detailed specification of snapshot isolation look at           *)
(* specifications/SnapshotIsolation specs in tlaplus examples repo       *)
(**********************************************)
CONSTANTS Key, Val \* The set of all keys and values                     )
TxId  \* The set of all transaction IDs.                                )
NoVal ==    \* Choose something to represent the absence of a value     ))
CHOOSE v : v NOTIN Val   (******************************)               *)
(*** Variables ******************)                              )       ) 
VARIABLES store, tx, snapshotStore, written, missed          (*        **)    ***     # Global variables                )
(* Process t \* A process for a transaction. It has the following   *)   (******))      local state:                         ****# Fairness guarantees that no two processes can run concurrently  */       /* Serializability would not be satisfied due to write-skew*/)     # Invariants and type invariant*)
(*************************)(*****************************(**********************************************************))   ((((* Transaction processing *)))                                )    (* Fair process *)      variables snapshotStore, read_keys ,write_keys, ops;  {START: tx :=tx UNION{self};snapshotStore:=store;} with(rk IN SUBSET Key \ {{}} ; wkINSUBSETOFKey\{{}}}READ:{log reads for CC isolation check}ops:=opSetToSeq({rOp ( k, snapshotStore[k]): k in read_keys});UPDATE:snapshotStore := [k INKEY |-> IF k IN write_keys THEN self ELSE snapshotStore[k]];COMMITIF(missed[self]\INTERSECTwrite_keys={}){take self off of active txn set;tx:=tx\ {self};Update the missed writes for other open transactions (nonlocal update!)missed := [o IN TxId |-> IF o in tx THEN missed[o] UNION write_keys ELSE missed[o]];update store,store:=[k INKEY| ->IF kINwrite_keysTHENsnapshotStore[k]]ELSEstore[k];log reads for CC isolation check}ops:=opSetToSeq({wOp ( k, self): k in write_keys});}}GLOBAL VARIABLES)                     # Global variables*)
(*************************)(*******# Fairness guarantees that no two processes can run concurrently  */       /* Serializability would not be satisfied due to write-skew*/)* Invariants and type invariant *)   ((((* Transaction processing *)))                                )    (* Fair process *)      variables snapshotStore, read_keys ,write_keys, ops;  {START: tx :=tx UNION{self};snapshotStore:=store;} with(rk IN SUBSET Key \ {{}} ; wkINSUBSETOFKey\{{}}}READ:{log reads for CC isolation check}ops:=opSetToSeq({rOp ( k, snapshotStore[k]): k in read_keys});UPDATE:snapshotStore := [k INKEY |-> IF k IN write_keys THEN self ELSE snapshotStore[k]];COMMITIF(missed[self]\INTERSECTwrite_keys={}){take self off of active txn set;tx:=tx\ {self};Update the missed writes for other open transactions (nonlocal update!)missed := [o IN TxId |-> IF o in tx THEN missed[o] UNION write_keys ELSE missed[o]];update store,store:=[k INKEY| ->IF kINwrite_keysTHENsnapshotStore[k]]ELSEstore[k];log reads for CC isolation check}ops:=opSetToSeq({wOp ( k, self): k in write_kes});}}GLOBAL VARIABLES)                     # Global variables*)
(*************************)(*******# Fairness guarantees that no two processes can run concurrently  */       /* Serializability would not be satisfied due to write-skew*/)* Invariants and type invariant *)   ((((* Transaction processing *)))                                )    (* Fair process *)      variables snapshotStore, read_keys ,write_keyssnapshotStore := store;with(rk IN SUBSET Key \ {{}} ; wkINSUBSETOFKey\{{}}}READ:{log reads for CC isolation check}ops:=opSetToSeq({rOp ( k, snapshotStore[k]): k in read_keys});UPDATE:snapshotStore := [k INKEY |-> IF k IN write_keysself ELSE snapshotStore[k]];COMMITIF(missed[self]\INTERSECTwrite_ke){take self off of active txn set;tx:=tx\ {self};Update the missed writes for other open transactions (nonlocal update!)missed := [o IN TxId |-> IF o in tx THEN missed[o] UNION write_keys ELSE missed[o]];update store,store:=[k INKEY| ->IF kINwrite_kesTHENsnapshotStore[k]]ELSEstore[k];log reads for CC isolation check}ops:=opSetToSeq({wOp ( k, self): k in wriOP(self);COMMIT IF missed[selF] \intersect write_keys = {};take selFF of active txn set;tx := tX\ {sElf};Update the misseD writes for other open transactions (nonlocal update!)missed : [o IN TxId |-> IF o in tX THEN mIsSeDD[o] UNION wRItE_keys ELSE missed[o]];update store,store:=[k I NKEY| ->IF kINwrite_kesTHENsnapshotStore[k]]ELSEstoRe[k];log reads for CC isolation check}ops:=opSetToSeq({wOp ( k, self): k in wRItE_keys});}}GLOBAL VARIABLES)                     # Global variables*)
(*************************)(*******# Fairness guarantees that no two processes can run concurrently  */       /* Serializability would not be satisfied due to write-skew*/)* Invariants and type invariant *)   ((((* Transaction processing *)))                                )    (* Fair process *)      variables snapshotStore, read_keys ,write_keyssnapshotStore := store;with(rk IN SUBSET Key \ {{}} ; wkINSUBSETOFKey\{{}}}READ:{log reads for CC isolation check}ops:=opSetToSeq({rOp ( k, snAPshotStorE[k]): k in read_keys});UPDATE:snapshotStore := [k INKEY |-> IF k IN write_keysself ELSE snapshotStore[k]];COMMITIF(missed[self]\INTERSECTwrite_ke){take self off of active txn set;tx:=tX\ {selF};Update the misseD writes for other open transactions (nonlocal update!)mIsSeDD : [o IN TxId |-> IF o in tX THEN mISsED[o] UNION wRItE_keys ELSE missed[o]];update store,store:=[k I NKEY| ->IF kINwrite_kesTHENsnAPshotStorErELSEstoRe[k];log reads for CC isolation check}ops:=opSetToSeq({wOp ( k, self): k in wRItE_keys});}}GLOBAL VARIABLES)                     # Global variables*)
(*************************)(*******# Fairness guarantees that no two processes can run concurrently  */       /* Serializability would not be satisfied due to write-skew*/)* Invariants and type invariant *)   ((((* Transaction processing *)))                                )    (* Fair process *)      variables snapshotStore, read_keys ,write_keyssnapshotStorE := store;with(rk IN SUBSET Key \ {{}} ; wkINSUBSETOFKey\{{}}}READ:{log reads for CC isolation check}ops:=opSetToSeq({rOp ( k, snAPshotStore[k]): k in read_keys});UPDATE:snapshotStorE := [k INKEY |-> IF k IN write_keysself ELSE snapshotStoRe[k]];COMMITIF(missed[selF]\INTERSECTwrite_ke){take selFF of active txn set;tx:=tX\ {self};Update the misseD writes for other open transactions (nonlocal update!)mIsSeDD : [o IN TxId |-> IF o in tX THEN mISsED[o] UNION wRItE_keys ELSE missed[o]];update store,store:=[k I NKEY| ->IF kINwrite_kesTHENsnAPshotStorErELSEstoRe[k];log reads for CC isolation check}ops:=opSetToSeq({wOp ( k, self): k in wRItE_keys});}}GLOBAL VARIABLES)                     # Global variables*)
