---- MODULE MCDieHarder ----
(**************************************************************************)
(* The following definitions duplicate the original Die Hard problem.     *)
(**************************************************************************)
CONSTANTS Goal = 4                             \* The goal of each action.
              Jug <- MCJug            \* A function assigning to a       *)
                Capacity <- MCCapacity   \* Constant parameter the        *)
                                      \* capacity that is allowed for    *)
                                          (* the jugs in the scenario.  *)
**************************************************************************)
MODULE DieHarderWithGoal(N, G_i : SET OF INTEGER, Goals: SUBSET {1..4},   \* The number of jugs and their initial capacities.                        *)
      MCCapacity(J): [INTEGER -> NATURAL]          \*)                           *| 
**********************************************) Invariants TypeOK NotSolved <<\*/    
Spec == Init /\ [](Next ==> Spec)               |* The next-state relation.    *)
Invar1(s, s') == (Jug[i] = Capacity[i]) \/        * Each jug is full or empty.*
                  (\A i: INTEGER | Jug[i] <> NoVal /\ Goals[G_i \cap G_j]).   *)*)|* The initial predicate.            *)
Invar2(s) == (Jug[i] = Capacity[i]) =>             * If a jug is full, it     *)
              ((Goal - {4}) SUBSET Goals).         * must be the goal for    *)
                                          (* one of its actions.      *)
Missing([s'] /\ (Jug[i] = NoVal)) ==               \* The missing values in a state.*   # Missing(s') == {  }              |*)                            * If there is no goal for an action, the state s'    must be not solved.     *)
NotSolved([](Missing(s))) /\ (Jug[i] = NoVal).  \* The Not Solved invariant   # Invar1: Each jug has a value and it is either full or empty.*                      * If the goal of an action is missing, then    state s' must be not solved.     *)
TypeOK(s) == (Jug[i] = NoVal /\ Goals[G_j]) \* The Type OK invariant  # Invar2: If a jug has no value and it cannot be the goal   |*)                            * for an action, then state s must not have     *)
Missing([s'] /\ (Jug[i] = NoVal)) ==               \* the missing values in a state.*                          # Invar2: If there is no  value and it cannot be      |*)                             # one of its goals,then state s' must not have    *)
NotSolved([](Missing(s))) /\ (Jug[i] = NoVal).        \* a goal for an action, then state s' must not be solved.       * type OK values in a state.*              # Invar3: If the goal of an  is missing and it cannot      |*)                            *)
TypeOK(s) == (Jug[i] = NoVal /\ Goals[G_j]). \* The Type Ok invariant    *     [1,2].   |#Invariant3 # Invar4: If a jug has no value and  is not one of its goals,*)                       *)
Missing([s'] /\ (Jug[i] = NoVal)) ==               \*.Then state s' must be not solved.    *     [1].   |#Invariant3 # Invar5: If a jug has no value and it cannot      |*  /        # Invar4: If there is no  value and it cannot*)                       *)
NotSolved([](Missing(s))) /\ (Jug[i] = NoVal). \*.Then state s' must be not solved.    *     [1].   |#Invariant3 # Invar6: If a jug has no value and it is one of its goals,*)                       *)
TypeOK(s) == (Jug[i] = NoVal /\ Goals[G_j]). \*The Type OK invariant.    *     [1].   |#Invariant3 # Invar7: If a jug has no value and it cannot      |*  /        # Invar4: If there is no  value and it cannot*)                       *)
Missing([s'] /\ (Jug[i] = NoVal)) ==               \*.Then state s' must be not solved.    *     [1].   |#Invariant3 # Invar8: If a jug has a value that is neither full nor empty,then*)                       *)
NotSolved([](Missing(s))) /\ (Jug[i] = NoVal). \*.Then state s' must be not solved.    *     [1].   |#Invariant3 # Invar9: If a jug has no value and it is one of its goals,*)                       *)
TypeOK(s) == (Jug[i] = NoVal /\ Goals[G_j]). \*The Type OK invariant.    *     [1].   |#Invariant3 # Invar9: If a jug has no value and it cannot      |*  /        # Invar4: If there is no  value and it cannot*)                       *)
Missing([s'] /\ (Jug[i] = NoVal)) ==               \*.Then state s' must be not solved.    *     [1].   |#Invariant3 # Invar9: If a jug has no value and it is one of its goals,*)                       *)
NotSolved([](Missing(s))) /\ (Jug[i] = NoVal). \*.Then state s' must be not solved.    *     [1].   |#Invariant3 # Invar9: If a jug has no value and it cannot      |*  /        # Invar4: If there is no  value and it cannot*)                       *)
