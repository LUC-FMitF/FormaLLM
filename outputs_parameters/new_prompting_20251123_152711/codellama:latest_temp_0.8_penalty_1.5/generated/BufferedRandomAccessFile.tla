(* This spec covers the core fields as well as seek(), write(data), flush()   *))
**************************[ General Contract of RandomAccessFile's read ]---*)
read == [ f |-> (file_content = \E elems : {0..MaxOffset} .* DOMAIN file_pointer & SUBSET Offsets => SPECIFY(elems)(f.data))]
**************************[ General Contract of RandomAccessFile's seek ]---*)
