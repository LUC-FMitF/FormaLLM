---- MODULE MultiPaxos ----
module MultiPaxos (G: Globals) {
    const Ballots = Set(0..NumReplicas);  // set of ballot numbers used for leader election and instance preparation, each replica tracks the maximum known ballo number it has received from a prepare message with its index in this variable. Each entry represents one round when deciding whether to accept an incoming command or not
    const Slots = Set(0..NumCommands);  // set of slots for storing commands sent by clients, each replica tracks the maximum value assigned so far and stores all values less than that index in this variable. Each entry represents one slot when deciding whether to accept an incoming command or not
    const Instances = Map(Slots -> (cmd: string) xor balPrepared : 0..NumReplicas); // map of instances being prepared, each replica tracks the maximum ballot number it has received for a given slot and stores all votes less than that index in this variable. Each entry represents one instance when deciding whether to accept an incoming command or not
    const ObservedEvents = Map(Commands -> Events);  // map of observed client events, each replica tracks the list of commands it has sent out so far and stores all other clients' responses with respecting this variable. Each entry represents one event when deciding whether to accept an incoming command or not
    const PendingInstances = Map(Slots -> (cmd: string) xor balPrepared : 0..NumReplicas); // map of pending instances, each replica tracks the list of commands it has received but not yet sent out and stores all votes less than that index in this variable. Each entry represents one instance when deciding whether to accept an incoming command or not
    const PeakVotedCmd = Map(Ballots -> Commands);  // map storing maximum voted commands, each replica tracks the largest value assigned so far for a given ballot number and stores all values less than that index in this variable. Each entry represents one slot when deciding whether to accept an incoming command or not
    const BallPrepared = Map(Ballots -> 0..NumReplicas); // map of prepared balls, each replica tracks the maximum ballot number it has received for a given instance and stores all votes less than that index in this variable. Each entry represents one slot when deciding whether to accept an incoming command or not
    const CommitUpTo = Map(Slots -> 0..NumReplicas); // map of commits up-to slots, each replica tracks the maximum value committed so far and stores all values less than that index in this variable. Each entry represents one slot when deciding whether to accept an incoming command or not
    const KValue = Map(Slots -> string xor (Commands)); // map of key-value pairs for storing commands, each replica tracks the list of sent out and stored commands so far but does not store other clients' responses with respecting this variable. Each entry represents one slot when deciding whether to accept an incoming command or not
    const GlobalVariables = Map(G -> (string xor int)); // map storing global variables, each replica tracks the list of sent out and stored commands so far but does not store other clients' responses with respecting this variable. Each entry represents one slot when deciding whether to accept an incoming command or no
}
