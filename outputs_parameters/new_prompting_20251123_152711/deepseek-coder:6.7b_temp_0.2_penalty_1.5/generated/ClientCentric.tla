---- MODULE ClientCentric -----   -- TLA+ specification of Client Centric Isolations by Crooks et al. and Tim Soethout (tim@soehthut) ---    -----------------------------------------------------------------------------------     LOCAL INSTANCE FiniteSets EXTENDS Sequences
LOCAL FUNCTION ReadStates(state: State, operation : Operation), WriteState[key](value): BOOLEAN  -- Helpers representing reads and writes on a state.   \* Check if an `operation` can read from the given 's'    def_ReadOperation == [k |-> v] /\ (v = ReadValue(state, operation))
LOCAL FUNCTION WriteStates[key](value): State  -- Helpers representing writes on a state.   \* Check if an `operation` can write to the given 's'    def_WriteOperation == [k |-> v] /\ (v = value) U ((state EXCEPT k))
LOCAL FUNCTION CTI(transaction: Transaction, execution : Execution): BOOLEAN  -- Check if a specific transaction satisfies isolation level.   \* Given system state and single operation sequence determines new State    def_NextState == IF (EXISTS i /\ [i |-> ReadStates[operation]](state) AND WriteOperation(key, value)) THEN ([k| - > v ] U ((IF key IN DOMAIN transaction.ops 
LOCAL FUNCTION CTI: Transaction \in transactions => EXIST execution : Execution in executions /\ (transaction = HeadElem[Transaction]execution ) IMPLIES def_NextState(HeadTailSeqs, TlTransactions) == State   -- Check if a specific transaction satisfies isolation level.
