---- MODULE BKModelCheckingExample----    \* Module Name *\    =====================  TLA+ Specification  ==============================================      CONSTANTS Bank = {...} , NotAnInput={..}, Inputs, Output ...etc in a separate module or at top of your main specification file if not already done.
------------------------------ MODULE HDiskSynod -----------------------------------------     (***************************************************************************)    (* Modification History *)      CONSTANTS   LastModified = "Sat Jan 26 15:52:41 CET 2019 by tthai", Created  =" Sat Jan 26 15:23:57 CET 2019 Byt th ai")      (***************************************************************************)
     LOCAL INSTANCE BKStateVariables   == {bk.bal, bk.inp}   /\ ...etc...LOCAL VARIABLES State == <<Bank>>VARIANTS InvariantForAllStates ==  [<>]_<<vars:={x | x \notin Bank } >>
     (* Define Operations *)    OPEN BKOperators== {Deposit, Withdrawal}   /\ ...etc...  OPERATIONS DepoWith ==      []bk.bal' = IF bko THEN (..) ELSE(...) TLA+ Syntax: [<>]_<<vars>>
     (* Define Invariants *)    INVARIANTS BKInvariant ==  (([](([x | x \in Bank ]-{NotAnInput})=Bank)) /\  ...etc... Spec == Init/\ [] (DepoWith)   TLA+ Syntax: [<>]_<<vars>>
     (* Define Initial State *)    INITIAL STATE BKInitialState ==  {bk.bal = 0, bko = NotAnInput}      CONSTANTS  LastModified  = "Sat Jan2615 :43 CETBy tthai", Created=" SatJan  7C ETT Byt th ai")
     (* Define Transition *)    TRANSITION BKTransitions ==  ([](DepoWith))      CONSTANTS  LastModified  = "Sat Jan2615 :43 CETBy tthai", Created=" SatJan  7C ETT Byt th ai")
     (* Define Specification *)    SPECIFIED BKSpec ==  Init/\ [] (DepoWith)      CONSTANTS  LastModified  = "Sat Jan2615 :43 CETBy tthai", Created=" SatJan  7C ETT Byt th ai")
     (* Define Config *)    TLC Configuration: BKConfig ==  MODEL Checking /\ COMMAND Line Options -dead 809,261,-543 --workers auto      CONSTANTS LastModified  = "Sat Jan  7C ETT Byt th ai", Created=" SatJan    CETBy tthai")
    =============================================================================  TLA+ Specification =======================================================  \* Module Name *\      == END OF MODULE BKModelCheckingExample ==      (***************************************************************************) (* Modified By:t th ai *)   CONSTANTS LastMod="Sat Jan2615 :43 CETBy tthai", Created  = " SatJan 7C ETT by TLA+ Tools")(*****************************************************END OF MODULE BKModelCheckingExample***************************************************************************)
