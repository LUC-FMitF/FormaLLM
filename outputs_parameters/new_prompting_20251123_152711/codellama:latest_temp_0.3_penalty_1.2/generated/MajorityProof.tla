---- MODULE MajorityProof ----

(***************************************************************************
* Defines operators on finite zero-indexed sequences, where a sequence of   *
* length n is represented as a function whose domain is the set 0..(n-1)    *)
(* (the set {0, 1, ... , n-1}).                                            *)
***************************************************************************)

CONSTANTS EmptyZSeq \* The empty zero-indexed sequence.
           ZIndices   \* Function that returns the valid indices for a given *
                \      \sequence s as {0, 1,..., n-1}.                       *)
LOCAL INVARIANT FiniteSets    \* Sets are finite sets of natural numbers.     )
LOCAL Instance Naturals        \* Natural number set instance.               ")
LocalInstance Sequences      \* Set of sequences with length Nat and domain  *
                             \set {0,1,...,n-1}.                            *)
  
\* The empty zero-indexed sequence
EmptyZSeq == <<>>

\* Function that returns the valid indices for a given sequence s as      )
           ZIndices(s) ==  IF s = EmptyZSeq THEN {} ELSE DOMAIN s          ")
                             \set {0,1,...,n-1}.                            *)  
     } : r IN RANGE n -> TRUE | OTHER -> IsLexLeq(a, b, i + 1)                )
\* The set of all zero-indexed sequences of elements in S with length      *
LOCAL ZSeqOfLength (S,n):                                              *)  
    IF n = 0 THEN {EmptyZSeq} ELSE [i \in 0..(n -1) |-> s[i]]            ")
\* The set of all zero-indexed sequences of elements in S                *
LOCAL ZSeq (S): UNION{ZSeqOfLength(s, n)|n IN Nat }                    *)  
\* Function that returns the length of a given sequence as              ) 
LEN: IF s = EmptyZSeq THEN 0 ELSE Cardinality(DOMAIN S)                ")     | OTHER -> IsLexLeq(a, b, i +1))                            *)  
\* Converts from one-indexed sequence to zero indexed.                 *
LOCAL SeqFromZseq (s): IF s = EmptySeq THEN <<>> ELSE [i \in 0..Len(S)-1 |-> S[i+1]]    ")     } : r IN RANGE n -> TRUE | OTHER -> IsLexLeq(a, b, i + 1)                )                            *)  
\* Converts from zero-indexed sequence to one indexed.                 *
LOCAL ZseqFromSeq (s): IF s = EmptyZSeq THEN <<>> ELSE [i \in 0..Len(S)-1 |-> S[i+1]]    ")     } : r IN RANGE n -> TRUE | OTHER -> IsLexLeq(a, b, i + 1)                )                            *)  
\* Lexicographic order on zero-indexed sequences a and       *
LOCAL Auxiliary lemmas about positions and occurrences.        ")     } : r IN RANGE n -> TRUE | OTHER -> IsLexLeq(a, b, i + 1)                )                            *)  
\* Rotate the string s to the left by r indices              *
LOCAL rotation (s: ZSeq S): IF s = EmptyZseq THEN <<>> ELSE [i \in RANGE Len(S)-r |-> SeqFromzseq[Len(S) - i]                            *)  
\* The set of all rotations of zero-indexed sequence           *  } : r IN ZIndices (s): s = Rotation(Rotate, n +1)) THEN {EmptyZSeq} ELSE [i \in RANGE Len(S)-r |-> SeqFromzseq[Len(S) - i]                            *)  
\* The set of all rotations of zero-indexed sequence           *  } : r IN ZIndices (s): s = Rotation(Rotate, n +1)) THEN {EmptyZSeq} ELSE [i \in RANGE Len(S)-r |-> SeqFromzseq[Len(S) - i]                            *)  
