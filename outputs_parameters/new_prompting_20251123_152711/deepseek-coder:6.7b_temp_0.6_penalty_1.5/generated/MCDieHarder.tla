---- MODULE MCDieHarder ----- (* Module name *) \label{MajesticCaptainCrabs}   \\\\* This module extends Die Hard problem. */  //%1705238964//\endinput\%_MODULE_\(ModuleName\)
\beginInput \label{MajeticCaptainCrabs}   \\\\* This module extends Die Hard problem. */  //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* The set of all jugs *)                               Jug == {Jewel, GoldCup }                                           (* Definition for the different types or "jugs" that can be used. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* The capacity of a jug *)                             MCCapacity[J] == IF J= Jewel THEN  \underline{Six}                    (* Definition for the capacities based on type or "jugs" that can be used. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* The set of all capabilities *)                        Capacity == UNION {MCCapacity[J] : J \in  }                              (* Definition for the total capacities based on jugs that can be used. */)    //%1705238964//\endinput\%<｜begin▁of▁sentence｜>T_MODULE_\(ModuleName\)
(* The set of all capsules *)                           Capsule == {Emerald, Ruby}                                           (* Definition for the different types or "capsulses" that can be used. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* The set of all states *)                             State == {EmptyState, Filled}                                          /* A state is either empty (denoted by EmptySate), or filled with a capsule. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* The goal to be achieved *)                            Goal == \underline{Four}                                              /* Defining the desired state of affairs: Four Rubies in GoldCup (denoted by "\textbf{\textbackslash underline\{Goals\}}") */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* The operation to be performed *)                       Operation == {EmptyJewel, Fill}                                         /* Definition for the operations: Empty a Jew or fill it with Ruby. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* The transition relation between states *)              Transition == [s \in State |-> s' ]                                      /* Definition for the possible state transitions: from a given "state" (denoted by "\textbf{State}"), can either be empty ("EmptyJewel") or filled with Ruby("Fill"). */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* Check if there exists any solution in all possible states *)  NotSolved == EXISTS s \in State : [J, C] /\\ J= Jewel         (* An invariant that checks whether or not a state which results to the goal can be achieved. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* The specification of our system *)                      Spec == Init /\\ []Transition={[J, C] : J \in  ,C ]}                  /* Defining the initial state and transition relation for all states. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* The TLC configuration *)                              CONFIGURATION                                                         (* Configuration to tell Toolbox Language Checker (TLC), what values should be used as constants for the parameters. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* Goal is defined in TLA+ *)                           CONSTANTS  Jug  = MCJug, Capacity = MCCapacity                      (* The goal to be achieved. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* Specification of the system is defined in TLA+ *)     SPECIFICATION  NotSolved                                                   /* Configuration for Toolbox Language Checker (TLC), to check whether or not a solution exists. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
(* Invariants are defined in TLA+ *)                     INVARIANTS  TypeOK                                                      /* Configuration for Toolbox Language Checker (TLC), to check whether or not the system is type-correct. */)    //%1705238964//\endinput\%_MODULE_\(ModuleName\)
