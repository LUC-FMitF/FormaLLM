---- MODULE ClientCentric ----- --------------------------------------------------
EXTENDS FiniteSets, Naturals, Sequences; -- Assumes these basic TLA+ libraries.  
CONSTANTS Keys = {...} /\ InitValue \in Values ;    --- Assume some keys and an initial value for the state.    
--------------------------------- Module Isolation -------------------------------     
(******************************************************************************)      
(* Defines operators on finite zero-indexed sequences, where a sequence of length n *)   (* is represented as a function whose domain is the set {0..n}.                                                    *)    (*************************************************)    
LOCAL INSTANCE State == [k \in Keys |-> InitValue]  -- Initial state.      --- Assume all keys have an initial value, which may be bottom (_|_).      
(* Operations are represented as pairs of key and values for read or write *)   (* operations:                                                       *)     (*************************************************)   
LOCAL INSTANCE Operation == [key : Key , val : Value]  -- A single operation.      --- Assume keys have associated Values in the state, which may be bottom (_|_).      
(* Transactions are represented as total orders of operations with start and commit timestamps *)   (* Operations:                                                       *)     (*************************************************)   
LOCAL INSTANCE Timestamp == Nat  -- A timestamp.      --- Assume natural numbers for time stamps, which may be bottom (_|_).      
(* Transaction is a total order of operations with start and commit timestamps *)   (* Operations:                                                       *)     (*************************************************)   
LOCAL INSTANCE Transactions == [ops : Seq(Operation),  -- A sequence of transactions.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
                                  start , commit : Timestamp]   (* Operations:                                                       *)     (*************************************************)   
(* ExecutionElem is a parent state and the resultant states after applying each Transaction  -- A single execution element.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
LOCAL INSTANCE Execution == Seq(ExecutionElement)   (* Operations:                                                       *)     (*************************************************)   
(* The parent state is the last operation in a sequence of transactions  -- A single execution element.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
LOCAL INSTANCE ExecutionElem == [parentState : State ,   (* Operations:                                                       *)     (*************************************************)   
                                  Transaction => Operation] /\ parentState \in States  -- A single execution element.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
(* The set of states generated by applying a sequence of transactions to the initial state is defined as follows: *)   (* Operations:                                                       *)     (*************************************************)   
LOCAL FUNCTION States == [t \in Transactions |-> NextState(Initial, t)]  -- A single execution element.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
(* The next state after applying a sequence of transactions to the initial state is defined as follows: *)   (* Operations:                                                       *)     (*************************************************)   
LOCAL FUNCTION NextState(s : State , t : Transaction) == -- A single execution element.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
  IF Cardinality((t \in Operations)) = 0 THEN s ELSE ApplyOperation[NextOp]   (* Operations:                                                       *)     (*************************************************)    where NextState(s : State , t : Transaction) == -- A single execution element.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
(* The next operation after applying a sequence of transactions to the initial state is defined as follows: *)   (* Operations:                                                       *)     (*************************************************)    where NextState(s : State , t : Transaction) == -- A single execution element.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
LOCAL FUNCTION ApplyOperation[op] ==  IF op \in Read THEN s ELSE UpdateKeyValueInMap   (* Operations:                                                       *)     (*************************************************)    where NextState(s : State , t : Transaction) == -- A single execution element.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
(* The next operation after applying a sequence of transactions to the initial state is defined as follows: *)   (* Operations:                                                       *)     (*************************************************)    where NextState(s : State , t : Transaction) == -- A single execution element.      --- Assume sequences for transaction ops, which may be bottom (_|_).      
