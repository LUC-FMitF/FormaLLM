---- MODULE ClientCentric ----
EXTENDS FiniteSets / Naturals / Sequences;  // assuming these modules exist, add your own if necessary.

(**********************************************************************************************************************)
(* TLA+ specifications of the client-centered isolation specification by Crooks et al:                                *)
(* https://dl.acm.org/doi/10.1145/3087801.3087802                                                                     )
(**********************************************************************************************************************)
CONSTANTS  // Assuming the following constants, add your own if necessary: InitValue = {}|-> Value; TimeStamp = >=0;\empty set\TimeOut=[]; ... etc...etc.
VARIABLES % State is represented by keys with corresponding values -------------------------------------------- KeyValues == [k : ({Keys}] ->> Values]
--------- OPERATOR OVERLOADING AND HELPERS FOR READ/WRITES / TRANSACTION ----- Operation = Read | Write; Transaction, ExecutionElem ==  {operations: Seq(Operation), start: TimeStamp , commit :TimeStamp }  * [parentState: State, transaction: Transactions, resultantstate: state]
LOCAL READS ::= \* Helpers representing reads and writes\ ReadsAndWrites == (k => v) / {Read/Write}; w(K=>V)->r(KeyValue); % Definition of write to read states.  Check keys for which a value has been written but not yet committed
LOCAL READSTATES ::= \* Helpers representing reads and writes\ ReadStates == [k => State] / {Read/Write}; s-{*}->>s_p; w(K=>V)->r(KeyValue); % Definition of read states. Check keys for which a value can be fetched
LOCAL COMMITTEST ::= \* Helpers representing Commit tests\ CTI,CTS == Transaction ->  ExecutionElem/Execution  / e => {parentState: State , transaction :Transaction} ; PrintT(<<"try execution",execution>>)  =>  SerializabilityDebug; % Definition of commit test
LOCAL SERIALIZABILITYDEBUG ::= \* Helpers representing serialization tests\ CT_SER == Transaction, Execution -> Bool/Serializable / e => {transaction:Transaction , parentState : State}; PrintT(<<"Execution not Serialized",execution>>) ; % Definition of commit test
LOCAL ISOLATIONLEVEL ::= \* Helpers representing isolation levels\ satisfyIsolationLevel == Transactions, CTI -> Bool/Serializable / e => {transactions:Transactions , cti :CTI}; PrintT(<<"Execution not Serialized",execution>>) ; % Definition of commit test
LOCAL EXECUTIONELEMS ::= \* Helpers representing Execution elements\ execution, transactions -> Seq([parentState=> State, transaction => Transaction]);  store [ parentstate: ,transaction :transactions] in accumulator;% calculate next state. All possible permutations of executions given set of transactions
LOCAL EXECUTION ::= \* Helpers representing Execution\ execution == Permutation(allPossiblePerms,initialState,[operations]) / [e => initialstate]; % lists all possible permutations  of operations/transactions. execute each transaction and update the state to new value
LOCAL PERMUTATION ::= \* Helpers representing Execution\ permulations == Permutation(allPossiblePerms,initialState,[operations]) / [e => initialstate]; % All possible permutations  of executions given set of transactions. execute each transaction and update the state to new value
--------------------------------------- MODULE ClientCentricIsolation--------------------------------------------------) END OF SPECIFICATION.") == {(EmptySet, EmptyMap)}; KeyValues = [k |-> InitValue]; % initialState definition  Level1 thus pass it in store ExecutionElem in accumulator.calculate next state
========================================================================================================================] (Key => Value)].CTS[transaction](e).PrintT(<<"Execution Serializable",execution>>);% Check types and definitions of derived specification for initialState, transactions; print all executions if no execution satisfies commit test  \* fall back to normal check
======================================================================================================================]] == { (Key=> Value) }.CTS[transaction](e).PrintT(<<"Execution Serializable",execution>>);% Check types and definitions of derived specification for initialState, transactions; print all executions if no execution satisfies commit test  \* fall back to normal check
========================================================================================================================]== { (Key=> Value) }.CTS[transaction](e).PrintT(<<"Execution Serializable",execution>>);% Check types and definitions of derived specification for initialState, transactions; print all executions if no execution satisfies commit test  \* fall back to normal check
