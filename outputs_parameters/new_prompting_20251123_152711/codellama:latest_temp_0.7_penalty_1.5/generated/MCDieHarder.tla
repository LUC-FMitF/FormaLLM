---- MODULE MCDieHarder ----
(****************************** THEOREM ****************************     *)
(* Defines the specification and invariants for a simplified version of  *)
(* The "Die Hard" problem.                              .               *)
(*****************************************************************      )   /    SYNTAX <syntax> == \A x : P(x)       >                # Specification         * A set of states satisfying the properties defined by Init and Next          *.  INVARIANTS TypeOK [Init /\ NotSolved]                            # Invariant for safety             *)
(* Defines a type invariant that ensures all solutions found have not   )     /    SYNTAX <syntax> == \E x : P(x)       >                ^ Specification         * An existence property satisfying the specification and initial predicate.      *.  INVARIANTS TypeOK [Init /\ NotSolved]                            # Invariant for safety             *)
   NOT SAFETY Init[MCCapacity <= MCJug, MCHeadroom > Goal - MCBullets + MCArmor]    ^ Specification         * An existence property satisfying the specification and initial predicate.      *.  INVARIANTS TypeOK [Init /\ NotSolved],                           # Invariant for safety             *)
   NOT SAFETY Next[MCJug' = Jug - MCFill, MCBullets', MCArmor'] == BulletDamage(MCHeadroom),  ^ Specification         * An existence property satisfying the specification and next-state relation.       *.                     NotSolved /\ (Init \/ !SOLVED)]]             # Invariant for safety
****************************** THEOREM ****************************    *)   /      SYNTAX <syntax> == [](<formula>)           >                = Specification         ** Existence property satisfying the specification and next-state relation.     *.                       NotSolved /\ (Init \/ !SOLVED)]]             # Invariant for safety
