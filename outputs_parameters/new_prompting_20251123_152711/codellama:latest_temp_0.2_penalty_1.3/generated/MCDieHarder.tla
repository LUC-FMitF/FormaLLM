---- MODULE MCDieHarder ----

(**************************************************************************)
(* The following definitions duplicate the original Die Hard problem.     *)
(**************************************************************************)
CONSTANTS Goal = 4   \* The goal of the game is to move all hostages out *)
                    \* of a building in this many minutes or less.        *)
VARIABLES Jug, Capacity, HostageCount, MinutesRemaining              (* A jug has capacity C and holds HC hostages.  If it's not empty, the game is over when MINUTES_REMAINING reaches zero.                          *)
-----------------------------------------------------------------------------
MCJug ==    \* Define a function to generate values for Jug that satisfy   *)
            \* constraints on Capacity and HostageCount.  This allows us     *)
            \* to use the same configuration file with different parameters.*)
LET                                                               (* The number of hostages in each jug is chosen so as not to exceed capacity, while still allowing for a solution.   *)
    HC = [hc |-> IF hc > Capacity THEN 0 ELSE (Capacity - hc)]     \* If the total number of hostages would be greater than or equal to the capacity, then set it to zero so that there are no more hostages in any jug. *)
    RECURSIVE HC' = [hc |-> IF hc > Capacity THEN 0 ELSE (Capacity - hc)] \* If the total number of hostages would be greater than or equal to the capacity, then set it to zero so that there are no more hostages in any jug. *)
    IN HC' = [hc |-> IF hc > Capacity THEN 0 ELSE (Capacity - hc)] \* If the total number of hostages would be greater than or equal to the capacity, then set it to zero so that there are no more hostages in any jug. *)
    HC'' = [hc |-> IF hc > Capacity THEN 0 ELSE (Capacity - hc)] \* If the total number of hostages would be greater than or equal to the capacity, then set it to zero so that there are no more hostages in any jug. *)
    HC''' = [hc |-> IF hc > Capacity THEN 0 ELSE (Capacity - hc)] \* If the total number of hostages would be greater than or equal to the capacity, then set it to zero so that there are no more hostages in any jug. *)
