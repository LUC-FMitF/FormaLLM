---- MODULE MCDieHarder ----

(***************************************************************************)
(* The following definitions duplicate the original Die Hard problem.       *)
(***************************************************************************)

CONSTANTS   Goal, Jug, Capacity: Nat                                        (* Defined in the configuration file. *)
VARIABLES   ammo : [1..Goal] -> BOOLEAN                                     (* The amount of ammunition for each goal.       *)
            mutations : [0..2*Goal] -> NATURAL                               (* The number of possible ways to achieve a      *)
                                                        \* given goal using at most 4 mutations.                           *)
INITIAL     == /\ ALL i: (1..Goal) | ammo[i] = FALSE         (* All goals start with no ammunition.                       *)
FINAL       == /\ ALL i: (1..Goal) | ammo[i] = TRUE          (* Each goal has ammunition by the end of the game.           *)
TRANSITION  ==                                                              (* The transitions are defined below, in the spec. *)
INITPRED    == \A s : INITIAL /\ FINAL -> FALSE                (* No initial state satisfies both the init and final preds.*)
FINALPRED   == /A s : INITIAL / \E i: (1..Goal) | ammo[i] = TRUE  (\* Every final state has at least one goal with ammunition. *)
                                          \* The transition system is complete if the spec satisfies the init and final preds.*)
                         /\ ALL s : FINAL / OTHERWISE FALSE   (* No other states satisfy the initial predicate or the       *)
                                                \* final predicate.                                                             *)
ACTIONS     == {A_MutateGoal(i), A_GiveAmmo(i)}               (\* The actions are defined below, in the spec.                  *)
                                            \* Mutation and giving ammo increase the number of mutations a goal can achieve.*)
LABELING    == {<[],[]>}                      (* An empty labeling is sufficient for this example.                *)
CONSTANTS_AND_VARIABLES_DECLARATION_FOR_TYPEOK  <-
            \* The constants and variables needed to check the type of Spec are:   *)
            [Goal, Jug, Capacity]                             (* Goal, Jug, and Capacity.                           *)
          /\ ACTIONS                               (\* All actions in the transition system.                *)
          / ALL i : (1..Goal) | ammo[i].          (\* The current amount of ammunition for each goal.             *)
        OBSERVABILITY_PROPERTY_FOR_TYPEOK            (* An observability property can be used if it is easier    *)
                  \* to check the type of Spec than using a model. For example, we could use this property:     *)
          / ALL s : INITIAL | FINAL.                (\* Every initial state has at least one goal with ammunition.*)
        NOT_SOLVED                            (* A special constant that can be used to check if a spec is unsatisfiable or not.*)

\* =============================== *
\*   The following definitions duplicate the original Die Hard problem.     *)
(\*)                              (\* In other words, this module duplicates                          *)
DieHarderWithMutationCapacities  <- DIE_HARD(Goal = 4, Jug = MCJug, Capacity = MCCapacity)      (* The original Die Hard problem.     *)
                           \* We define the functions used in the configuration file here:        *)
MCJug          == LET j \in Nat |- NATURAL IN {0..2}            (* A function that maps each natural number n to    *)
                             \* a nonnegative integer less than 3. In this case, we will use           *)
                               \* Jug as the number of mutations allowed. This is necessary because     *)
                               \* TLC does not allow one to write function-valued expressions in      *)
                               \* a configuration file. So, we use this module, which extends          *)
                             \* module DieHarderWithMutationCapacities to define a function MCCapacity  *)
                                        and have the configuration file TLC substitute MCCapacity for     (* Capacity. Since we need to know the value of Jug      *)
                                \* to define Capacity (which is a function having Jug as its domain), we also   *)
                             \* define MCJug and tell TLC to substitute it for Jug.                        (\*)
MCCapacity(n)  == LET j = Jug[n] |- NATURAL IN {0..2}            (* A function that maps each natural number n     *)
                    \* to a nonnegative integer less than 3, which is used to define the Capacity of        *)
                      \* each goal. In this case, we will use MCCapacity as the number of mutations for       *)
                          \* achieving each goal using at most 4 mutations. This is necessary because TLC    *)
                            \* does not allow one to write function-valued expressions in a configuration   *)
                             \* file. So, we use this module, which extends module DieHarderWithMutationCapacities        (* to define a function MCCapacity and have the  *)
                \* configuration file TLC substitute MCCapacity for Capacity. Since we need to know the value   *)
               \* of Jug to define Capacity (which is a function having Jug as its domain), we also              *)
             \* define MCJug and tell TLC to substitute it for Jug.                        (\*)
            INITIAL     == /\ ALL i: (1..Goal) | ammo[i] = FALSE         (* All goals start with no ammunition.           *)
                FINAL       == /\ ALL i: (1..Goal) | ammo[i] = TRUE          (* Each goal has ammunition by the end of    *)
                                            \* the game.                              (\*)   The following definitions duplicate the original Die Hard problem.     *)
