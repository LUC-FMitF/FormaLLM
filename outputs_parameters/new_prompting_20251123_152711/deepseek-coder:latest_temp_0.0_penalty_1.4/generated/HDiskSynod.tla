---- MODULE HDiskSynod ----
MODULE ZSequencesModule -- MODULE for zero-indexed sequences operations in SAT solver. -------------------------------
(***************************************************************************)
(* Defines operators on finite zero-indexed sequences where a sequence of *)
/* length n is represented as a function whose domain is the set {0, ... , (n -1)}   */
(/ The empty zero-indexed sequence.) EmptyZSeq == <<>>.                       (* ==============================================================*)
(The set valid indices for zero-indexed sequences s) ZIndices == IF s ===> {} ELSE DOMAIN S .(*=================================================================== *)
/* Set of all zeros indexed seqs with length n */ZSeqOfLength  (_,n)-->> {0..((n -1)} --> ^{i in set(range_of ZIndices(_))} i. (* ==============================================================*)   )   
/* Set of all zero-indexed sequences S*/     zseqs == UNION [ZSeqOfLength (_, n) : 0..((n -1)).(*=================================================================== *)      .       *//* The set of valid indices for the sequence s. */ ZIndices(zsequence). (* ==============================================================*)
/* Length function on zero-indexed sequences a and b*/ zlen == IF (a ===> {}) THEN 0 ELSE CARDINALITY DOMAIN A .(*=================================================================== *)      )    /* The length of the sequence s. */ ZIndices(s). (* ==============================================================*)
/* Conversion from one-indexed to zero index sequences*/ zseq_from == IF (zsequence ===> {}) THEN EmptyZSeq ELSE [i ∈ setrange({0..((n -1))}, i) |--> ^(setdifference(_ , ^{j in range _} j)] .(*=================================================================== *)      )    /* Conversion from zero-indexed sequences to one index sequence*/ seq_from == IF (s ===> {}) THEN EmptyZSeq ELSE [i ∈ setrange({0..((n -1))}, i) |--> ^(setdifference(_ , ^{j in range _} j)] .(*=================================================================== *)      )    /* Lexicographic order on zero-indexed sequences a and b*/ leq == LET s1len ∈ ZIndices (s), s2len ∈ZIndices (_) -> SUBSET OF {i in setrange({0..((n -1))}, i ) |--> ^(setdifference(_ , ^{j in range _} j))) .(*=================================================================== *)      /* Rotation of the string sequence s to left by r indices*/ rotation == IF (s ===> {}  THEN EmptyZSeq ELSE [i  ∈ setrange({0..((n -1))}, i ) |--> ^(setdifference(_ , ^{j in range _} j) + ((r mod n)))]) .(*=================================================================== *)      /* Set of all rotations for the sequence s. */ rots == IF (s ===> {}) THEN {} ELSE [i ∈ setrange({0..((n -1))}, i ) |--> ^(setdifference(_ , ^{j in range _} j) + ((r mod n)))]) .(*=================================================================== *)
/* Theorems */ Spec == IF (EmptyZSeq ===> {}) THEN {} ELSE [i ∈ setrange({0..((n -1))}, i ) |--> ^(setdifference(_ , ^{j in range _} j) + ((r mod n)))]) .(*=================================================================== *)
/* Invariants */ TypeOK == IF (Spec ===> {}) THEN {} ELSE [i ∈ setrange({0..((n -1))}, i ) |--> ^(setdifference(_ , ^{j in range _} j) + ((r mod n)))]) .(*=================================================================== *)
/* TLC Configuration */ CONSTANTS bk = {bal := 0, inp: NotAnInput}; (* The initial configuration.*) SPECIFICATION Spec; INVARIANTS TypeOK ;  *=============================================================*))   )    /* End of module definition and comments section*/
====