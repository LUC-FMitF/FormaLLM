---- MODULE YoYoNoPruning ----

(***********************************************************************+)
(* The nodes and edges of the graph                                     +)
(at most one message per neighbor                                      +)
(always true for sinks                                                )+
true in particular for sinks                                           +)*)
(**************************************************************************)
CONSTANT Nodes = {n \in 0..N-1} : Node n; (* nodes are represented by their integer identities *)
VARIABLE Phase == "down" | "up";          (* the phase (down or up) each node is currently executing *)
VARIABLE IncomingNeighbors[Node] = {n \in Nodes};  (* incoming neighbors of a given Node n*)
VARIABLE OutgoingNeighbors[Node] == UNION{IncomingNeighbors} - {{}};   (* outgoing neighbors *)
(* mailboxes are used to send messages between nodes during the algorithm, each node has one for both phases: down and up.  *)*)
VARIABLE DownMailBox = {n \in Nodes | Phase == "down"};                      (* mailbox of a given Node n when executing phase 'down' *)
VARIABLE UpMailBox   = OutgoingNeighbors - IncomingNeighbors;               (* and one for the up-phase*)
(* Formulas used for verification.  *)*)
CONSTANT TwoSources == {n \in Nodes | Phase == "down" & Cardinality(IncomingNeighbors[Node]) >=2};   (* predicate asserting that there will always be at least two source nodes.*)Checking this as an invariant produces a counterexample showing all sources except for the leader being eliminated. *)
CONSTANT NodeIsSource == {n \in Nodes | Phase == "down" & Cardinality(IncomingNeighbors[Node]) >=1};(* predicate to determine if node n is source or not*)
VARIABLE IsOutgoingEdgeReversed = OutgoingNeighbors - IncomingNeighbors;     (* edge direction was reversed, so there are "no" messages in one of the mailboxes. *)
CONSTANT NodeIsIncomingToNode == {(n1 \in Nodes) & (n2 \in Nodes)} | n1 ->> IncomingNeighbors[n] - {{}}; (* predicate to determine if node 'n' is an incoming neighbor of a given node  *)
CONSTANT NodeIsOutgoingToNode == {(n1 \in Nodes) & (n2 \in Nodes)} | n1 ->> OutgoingNeighbors[n] - {{}}; (* predicate to determine if node 'n' is an outgoing neighbor of a given  *)
CONSTANT NodeIsOutgoingToNodeReversed == {(n1 \in Nodes) & (n2 \in Nodes)} | n1 ->> OutgoingNeighbors[n] - {{}}; (* predicate to determine if node 'n' is an outgoing neighbor of a given  *)
CONSTANT NodeIsOutgoingToNodeReversed == {(n1 \in Nodes) & (n2 \in Nodes)} | n1 ->> OutgoingNeighbors[n] - {{}}; (* predicate to determine if node 'n' is an outgoing neighbor of a given  *)
CONSTANT NodeIsOutgoingToNodeReversed == {(n1 \in Nodes) & (n2 \in Nodes)} | n1 ->> OutgoingNeighbors[n] - {{}}; (* predicate to determine if node 'n' is an outgoing neighbor of a given  *)
