Die Hard problem.                              *)
(**********************************************)
CONSTANTS Goal     =  4    \* Target number of bottles to collect       *)
          Jug      <- 3    \* Number of bottle jugs (1 or more)         *)
          Capacity <- [j |-> j <= 2]            \* Bottle capacity for each jog                        *)
MODULE DieHarder(Goal,Jug,Capacity):           (* The following definitions duplicate the original *)
    die Hard problem.     ***************************)
CONSTANTS Goal = 4                             \* Target number of bottles to collect       *)
          Jug   <- MCJug(Goal, Capacity)        \* Number of jugs (1 or more), with capacity for each jog    *)
