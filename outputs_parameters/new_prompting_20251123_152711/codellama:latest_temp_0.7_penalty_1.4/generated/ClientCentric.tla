---- MODULE ClientCentric ----
------------------------------ STATE SYSTEM ----------------------------
CONSTANTS  Keys = {k1, k2}       # The set of keys in the system.
          VALUES      = {v0, v1}   # A finite value domain for key values.
INITIAL    State     == << >>                            InitValue >-> Values : initialState;
VARIABLES  ExecutionElem        -- An execution element represents a transaction and its parent state in the system's history.
          TimeStamp       = {t1, t2}   # A set of timestamps used to generate sequential transactions with different start times (wall clock time).
TRANSACTIONS Transaction == [ops: Seq(Operation), start :TimeStamp]     -- An atomic transaction is a sequence of operations and their associated timestamp.
                           | WriteOp   = {k1 -> v0, k2->v1}              # A write operation updates the values for two keys in the system (with different value domains).
FUNCTIONS  InitValue        == << >>             -- The initial state is an empty map.
          Executions(initialState)       :: [ExecutionElem]               -- Generate all possible permutations of a given set of transactions and their parent states, which form the system's history under sequential consistency (serializability). Each transaction has one read-state associated with it that contains its initial state.
          Executions(initialState)       :: [ExecutionElem]               -- Generate all possible permutations of a given set of transactions and their parent states, which form the system's history under sequential consistency (serializability). Each transaction has one read-state associated with it that contains its initial state.
          SatisfyIsolationLevel(transactions) :: [ExecutionElem]           -- Check if a given set of transactions can be executed in isolation level SERIALIZABILITY, where each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          SatisfyIsolationLevel(transactions) :: [ExecutionElem]           -- Check if a given set of transactions can be executed in isolation level SERIALIZABILITY, where each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          ExecutionIsSerializable(execution) :: Bool                     -- Check if a given execution satisfies serializability for transactions with different start times in wall clock time order, i.e., each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          ExecutionIsSerializable(execution) :: Bool                     -- Check if a given execution satisfies serializability for transactions with different start times in wall clock time order, i.e., each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          StateIsConsistent(s) :: Bool                  -- Check if a given state satisfies consistency for transactions with different start times in wall clock time order, i.e., each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          StateIsConsistent(s) :: Bool                  -- Check if a given state satisfies consistency for transactions with different start times in wall clock time order, i.e., each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          ExecutionsAreConsistent(execs) :: Bool         -- Check if a given set of executions satisfies consistency for transactions with different start times in wall clock time order, i.e., each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          ExecutionsAreConsistent(execs) :: Bool         -- Check if a given set of executions satisfies consistency for transactions with different start times in wall clock time order, i.e., each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          PrintT(state) :: Bool                        -- Pretty print a state as an ordered list of key/value pairs for debugging purposes only and without any assumptions about its validity or consistency, i.e., it does not check if each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          PrintT(state) :: Bool                        -- Pretty print a state as an ordered list of key/value pairs for debugging purposes only and without any assumptions about its validity or consistency, i.e., it does not check if each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          PrintT(execution) :: Bool                   -- Pretty print an execution as a list of transactions and their parent state for debugging purposes only, i.e., it does not check if each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          PrintT(execution) :: Bool                   -- Pretty print an execution as a list of transactions and their parent state for debugging purposes only, i.e., it does not check if each write operation is checked to ensure all previous states are read-only (i.e., no other transaction has written the same keys).
          ExecutionToState(execution) :: State         -- Convert an execution into its corresponding system state by mapping each atomic transaction in sequence to a new map with updated values, and then combining them as needed for consistency under sequential consistencey (serializability), i.e., it does not check if the resulting states satisfy isolation level SERIALIZABILITY or CONSISTENCY.
          ExecutionToState(execution) :: State         -- Convert an execution into its corresponding system state by mapping each atomic transaction in sequence to a new map with updated values, and then combining them as needed for consistency under sequential consistencey (serializability), i.e., it does not check if the resulting states satisfy isolation level SERIALIZABILITY or CONSISTENCY.
          ExecutionToState(executions) :: State       -- Convert a set of executions into their corresponding system state by mapping each atomic transaction in sequence to a new map with updated values, and then combining them as needed for consistency under sequential consistencey (serializability), i.e., it does not check if the resulting states satisfy isolation level SERIALIZABILITY or CONSISTENCY.
          ExecutionToState(executions) :: State       -- Convert a set of executions into their corresponding system state by mapping each atomic transaction in sequence to a new map with updated values, and then combining them as needed for consistency under sequential consistencey (serializability), i.e., it does not check if the resulting states satisfy isolation level SERIALIZABILITY or CONSISTENCY.
