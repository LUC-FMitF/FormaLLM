(***************************************************************************)
\* This module defines a Two-Phase Commit protocol to transfer Vouchers   *)
between two holders, where the transaction is coordinated by one         *)
process (VTP).                                                            *)
(**************************************************************************)
LOCAL INSTANCE FiniteSets
LOCAL InSTance Naturals
LOCAL Instance Sequences
  
\* The set of all possible vouchers.  Vs is a finite, non-empty subset    *)
\* of the natural numbers and represents the set of all existing        *)
voucher IDs in this system.                                              *)
V == {1..3}

\* A source holder (SH) prepares to transfer vouchers from Vs.  In our   *)
\* simplified spec, we do not model how SHs are selected for the        *)
transaction and whether they have any existing voucher IDs in their     *)
holdings; this is left as an exercise for the reader (see RFC           *)
3506).                                                                   *)
SH == {src1, src2, src3}

\* A destination holder (DH) prepares to receive vouchers from Vs.  In    *)
our simplified spec, we do not model how DHs are selected for the       *)
transaction and whether they have any existing voucher IDs in their     *)
holdings; this is left as an exercise for the reader (see RFC           *)
3506).                                                                   *)
DH == {dst1, dst2, dst3}

\* The set of all possible messages.  Messages of type "Prepared" are    *)
\* sent from SHs to the VTP and DHs; similar for Transfer and Abort     *)
messages.                                                                *)
MESSAGES == { Prepared, Transferred, Aborted }
  
CONSTANTS \* The set of all possible states that a voucher can be in      *)
vState[V] = [Pending | Committed | Revoked ]  *\/)                       *)
LOCAL INVARIANT VTPTypeOK == (SH, DH) -> { Prepared } \/ {}             *)
CONSTANTS vlcState[V] = [Active | Inactive ]                            *)
  
INVARIANT vtpConsistent ==  SHs + DHs - {vsh} *\/)                       *)
LOCAL INVARIANT VTPTypeOK == (SH, DH) -> { Prepared } \/ {}             *)
CONSTANTS shState[SH] = [Pending | Committed ]  /\*)                     *)
CONSTANTS dhState[DH] = [Pending | Committed ]   *\/)                    *)
LOCAL INVARIANT VTPTypeOK == (SH, DH) -> { Prepared } \/ {}      *)
INVARIANT vtpConsistent ==  SHs + DHs - {vsh} /\*\)              *)
CONSTANTS msgs[V] = [Pending | Committed ]                       *)
  
\* The initial predicate. *\/                                     *)
INITIALIZATION VTPTypeOK && vtpConsistent                          *)

ACTIONS \/ { Prepared } -> SHs + DHs - {vsh} /\*)                  *)
LOCAL INVARIANT VTPTypeOK == (SH, DH) -> { Prepared } \/ {}      *)
CONSTANTS shState[SH] = [Pending | Committed ]   *\/)                *)
INVARIANT vtpConsistent ==  SHs + DHs - {vsh} /\*\)                    *)
ACTIONS -> VTPs + SHs + DHs - {vdh} \/ {}     */*)                      *)
