CONSTANTS dhState[DH] = [Pending | Committed ]   *\/)                *)
INVARIANT vtpConsistent ==  SHs + DHs - {vdh} /\*\)                    *)
ACTIONS -> VTPs + SHs + DHs - {vsh, vdp} \/ {} */*)                      *)
